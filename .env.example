# ══════════════════════════════════════════════════════════════
# ElderShield — Environment Variables
# ══════════════════════════════════════════════════════════════

# Groq API Key (for blazing fast Whisper transcription and L2 fallback)
GROQ_API_KEY=gsk_your-key-here

# Gemini API Key (alternative for L2 classification)
GEMINI_API_KEY=AIzaSy_your-key-here

# ArmorClaw HMAC-SHA256 Secret (change in production!)
ARMORCLAW_SECRET=super-secret-hmac-key-change-in-prod

# Database path (SQLite)
DB_PATH=./eldershield.db

# Gemma 2B model path (local inference)
GEMMA_MODEL_PATH=./ml/models/gemma_scam_classifier

# Confidence threshold for GPT-4o fallback escalation
CONFIDENCE_THRESHOLD=0.80

# Family dashboard webhook URL
FAMILY_WEBHOOK_URL=http://localhost:3000/api/alerts

# Server configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
